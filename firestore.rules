rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.role == "admin";
    }

    function isValidProduct(data) {
      return data.keys().hasOnly([
          "name",
          "price",
          "category",
          "subcategory",
          "desc",
          "inStock",
          "stockStatus",
          "img",
          "active",
          "createdAt",
          "updatedAt"
        ])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.price is number
        && data.price >= 0
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 50
        && (!("subcategory" in data)
          || (data.subcategory is string
            && data.subcategory.size() > 0
            && data.subcategory.size() <= 50))
        && data.desc is string
        && data.desc.size() <= 1000
        && data.img is string
        && data.img.size() <= 2048
        && data.inStock is bool
        && (!("stockStatus" in data)
          || (data.stockStatus is string
            && data.stockStatus in ["disponible", "agotado", "proximo_ingreso"]))
        && data.active is bool;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);

      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly(["uid", "name", "email", "role", "createdAt"])
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 160
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.role in ["admin"];

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
